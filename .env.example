# ─── Supabase (nouvelles clés sb_publishable_ / sb_secret_) ──
# Web (client + serveur) — clé PUBLISHABLE (sûre côté navigateur, RLS appliquée)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Serveur uniquement (clé SECRET : bypass RLS — ne JAMAIS exposer au navigateur)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Connexion directe Postgres (migrations)
DATABASE_URL=

# ─── MyPuls (ingestion) — SECRETS, jamais en clair dans le code ──
MYPULS_EMAIL=
MYPULS_PASSWORD=
MYPULS_API_KEY=

# ─── IA (analyse à la demande) ──────────────────────────────
ANTHROPIC_API_KEY=

# ─── Alertes ingestion (échec du refresh) ───────────────────
TG_BOT_TOKEN=
TG_CHAT_ID=

# Revalidation du cache web après ingestion (secret partagé web ↔ worker)
REVALIDATE_SECRET=
REVALIDATE_URL= # ex. https://<app>.vercel.app/api/revalidate

# ─── Impersonation ──
# Secret HMAC dédié pour signer le cookie d'état (≠ clés Supabase). openssl rand -hex 32
IMPERSONATION_COOKIE_SECRET=

# ─── Sentry ─────────────────────────────────────────────────
# DSN web (inliné au build Next — pas un secret critique)
NEXT_PUBLIC_SENTRY_DSN=
# Tag d'environnement Sentry ('production' par défaut ; 'preprod' via .env.preprod)
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Upload des source maps au build (org/project du dashboard Sentry) — build local only
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
