# ─── Supabase ───────────────────────────────────────────────
# Web (client + serveur)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Serveur uniquement (service-role : bypass RLS — ne JAMAIS exposer au navigateur)
SUPABASE_SERVICE_ROLE_KEY=
# Connexion directe Postgres (migrations / ingestion)
SUPABASE_URL=
DATABASE_URL=

# ─── MyPuls (ingestion) — SECRETS, jamais en clair dans le code ──
MYPULS_EMAIL=
MYPULS_PASSWORD=
MYPULS_API_KEY=

# ─── IA (analyse à la demande) ──────────────────────────────
ANTHROPIC_API_KEY=

# ─── Alertes ingestion (échec du refresh) ───────────────────
TG_BOT_TOKEN=
TG_CHAT_ID=

# ─── Sentry ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
